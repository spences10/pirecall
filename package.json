{
	"name": "pirecall",
	"version": "0.1.1",
	"description": "Sync pi.dev agent sessions to SQLite and recall context from past sessions",
	"keywords": [
		"analytics",
		"context",
		"memory",
		"pi",
		"recall",
		"sqlite"
	],
	"homepage": "https://github.com/spences10/pirecall#readme",
	"bugs": {
		"url": "https://github.com/spences10/pirecall/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spences10/pirecall.git"
	},
	"bin": {
		"pirecall": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/resumable.d.ts",
			"import": "./dist/resumable.js"
		},
		"./resumable": {
			"types": "./dist/resumable.d.ts",
			"import": "./dist/resumable.js"
		}
	},
	"scripts": {
		"build": "vp pack && cp src/schema.sql dist/schema.sql && mkdir -p dist/migrations && cp src/migrations/*.sql dist/migrations/",
		"dev": "vp pack --watch",
		"start": "node ./dist/index.js",
		"check": "vp check",
		"check:fix": "vp check --fix",
		"format": "vp check --fix",
		"test": "vp test",
		"test:watch": "vp test watch",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "pnpm run build && changeset publish"
	},
	"dependencies": {
		"citty": "^0.2.2",
		"tinyglobby": "^0.2.16"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@types/node": "^25.9.0",
		"vite-plus": "^0.1.21",
		"vitest": "^4.1.6"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "pnpm@11.1.3"
}
